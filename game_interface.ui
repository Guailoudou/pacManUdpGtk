<?xml version="1.0" encoding="UTF-8"?>
<!-- Generated with glade 3.40.0 -->
<interface>
  <requires lib="gtk+" version="3.20"/>
  
  <!-- 对象树根节点：主窗口 -->
  <object class="GtkWindow" id="main_window">
    <property name="can_focus">False</property>
    <property name="title" translatable="yes">超级吃豆人追逐战</property>
    <property name="default_width">800</property>
    <property name="default_height">600</property>
    <child>
      <object class="GtkStack" id="app_stack">
        <property name="visible">True</property>
        <property name="can_focus">False</property>
        <property name="transition_type">slide-left</property>
        <property name="transition_duration">400</property>
        
        <!-- 页面 1: 房间选择界面 -->
        <child>
          <object class="GtkPaned" id="lobby_paned">
            <property name="visible">True</property>
            <property name="can_focus">True</property>
            <property name="position">400</property>
            
            <!-- 左侧面板：创建房间 -->
            <child>
              <object class="GtkBox" id="left_box">
                <property name="visible">True</property>
                <property name="can_focus">False</property>
                <property name="orientation">vertical</property>
                <property name="halign">center</property>
                <property name="valign">center</property>
                <property name="spacing">10</property>
                <child>
                  <object class="GtkLabel" id="label_create_title">
                    <property name="visible">True</property>
                    <property name="label" translatable="yes">创建房间</property>
                    <property name="width_chars">20</property>
                  </object>
                </child>
                <child>
                  <object class="GtkBox" id="create_port_box">
                    <property name="visible">True</property>
                    <property name="can_focus">False</property>
                    <property name="spacing">5</property>
                    <child>
                      <object class="GtkLabel" id="label_port_hint">
                        <property name="visible">True</property>
                        <property name="label" translatable="yes">端口:</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkSpinButton" id="spin_create_port">
                        <property name="visible">True</property>
                        <property name="can_focus">True</property>
                        <property name="adjustment">adjustment_port</property>
                        <property name="numeric">True</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="btn_create_room">
                    <property name="label" translatable="yes">创建房间</property>
                    <property name="visible">True</property>
                    <property name="can_focus">True</property>
                    <property name="receives_default">True</property>
                    <signal name="clicked" handler="on_create_room_clicked" swapped="no"/>
                  </object>
                </child>
              </object>
              <packing>
                <property name="resize">False</property>
                <property name="shrink">True</property>
              </packing>
            </child>
            
            <!-- 右侧面板：加入房间 -->
            <child>
              <object class="GtkBox" id="right_box">
                <property name="visible">True</property>
                <property name="can_focus">False</property>
                <property name="orientation">vertical</property>
                <property name="halign">center</property>
                <property name="valign">center</property>
                <property name="spacing">10</property>
                <child>
                  <object class="GtkLabel" id="label_join_title">
                    <property name="visible">True</property>
                    <property name="label" translatable="yes">加入房间</property>
                    <property name="width_chars">20</property>
                  </object>
                </child>
                <child>
                  <object class="GtkBox" id="join_ip_box">
                    <property name="visible">True</property>
                    <property name="can_focus">False</property>
                    <property name="spacing">5</property>
                    <child>
                      <object class="GtkLabel" id="label_ip_hint">
                        <property name="visible">True</property>
                        <property name="label" translatable="yes">IP:</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkEntry" id="entry_join_ip">
                        <property name="visible">True</property>
                        <property name="can_focus">True</property>
                        <property name="text" translatable="yes">127.0.0.1</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkBox" id="join_port_box">
                    <property name="visible">True</property>
                    <property name="can_focus">False</property>
                    <property name="spacing">5</property>
                    <child>
                      <object class="GtkLabel" id="label_join_port_hint">
                        <property name="visible">True</property>
                        <property name="label" translatable="yes">端口:</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkSpinButton" id="spin_join_port">
                        <property name="visible">True</property>
                        <property name="can_focus">True</property>
                        <property name="adjustment">adjustment_port</property>
                        <property name="numeric">True</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="btn_join_room">
                    <property name="label" translatable="yes">加入房间</property>
                    <property name="visible">True</property>
                    <property name="can_focus">True</property>
                    <property name="receives_default">True</property>
                    <signal name="clicked" handler="on_join_room_clicked" swapped="no"/>
                  </object>
                </child>
              </object>
              <packing>
                <property name="resize">True</property>
                <property name="shrink">True</property>
              </packing>
            </child>
          </object>
          <packing>
            <property name="name">page_lobby</property>
          </packing>
        </child>
        <!-- 等待界面 -->
        <child>
         
          <object class="GtkBox" id="waiting_bok">
            <property name="visible">True</property>
            <property name="can_focus">False</property>
            <property name="orientation">vertical</property>
            <property name="halign">center</property>
            <property name="valign">center</property>
            <property name="spacing">10</property>
            <!-- 等待 -->
            <child>
              <object class="GtkLabel" id="label_waiting">
                <property name="visible">True</property>
                <property name="label" translatable="yes">等待连接ing...</property>
                <property name="xalign">0</property>
                <attributes>
                  <attribute name="weight" value="bold"/>
                  <attribute name="scale" value="1.2"/>
                </attributes>
              </object>
            </child>
            <child>
              <object class="GtkLabel" id="label_waiting_info">
                <property name="visible">True</property>
                <property name="label" translatable="yes">鬼要5s后才能移动...</property>
                <property name="xalign">0</property>
                <attributes>
                  <attribute name="weight" value="bold"/>
                  <attribute name="scale" value="1.2"/>
                </attributes>
              </object>
            </child>
          </object>
          <packing>
            <property name="name">page_waiting</property>
          </packing>
        </child>
        <!-- 页面 2: 游戏界面 (100x100 格子) -->
        <child>
          <object class="GtkBox" id="game_box">
            <property name="visible">True</property>
            <property name="can_focus">False</property>
            <property name="orientation">vertical</property>
            
            <!-- 顶部信息栏：分数和时间 -->
            <child>
              <object class="GtkBox" id="top_info_box">
                <property name="visible">True</property>
                <property name="can_focus">False</property>
                <property name="margin_start">10</property>
                <property name="margin_end">10</property>
                <property name="margin_top">5</property>
                <property name="margin_bottom">5</property>
                <property name="spacing">20</property>
                <child>
                  <object class="GtkLabel" id="label_score">
                    <property name="visible">True</property>
                    <property name="label" translatable="yes">分数: 0</property>
                    <property name="xalign">0</property>
                    <attributes>
                      <attribute name="weight" value="bold"/>
                      <attribute name="scale" value="1.2"/>
                    </attributes>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel" id="label_time">
                    <property name="visible">True</property>
                    <property name="label" translatable="yes">时间: 00:00</property>
                    <property name="xalign">0</property>
                    <attributes>
                      <attribute name="weight" value="bold"/>
                      <attribute name="scale" value="1.2"/>
                    </attributes>
                  </object>
                </child>
              </object>
              <packing>
                <property name="expand">False</property>
                <property name="fill">True</property>
                <property name="position">0</property>
              </packing>
            </child>
            
            <!-- 中间游戏区域 + 右侧控制区 -->
            <child>
              <object class="GtkPaned" id="game_paned">
                <property name="visible">True</property>
                <property name="can_focus">True</property>
                <property name="position">600</property>
                
                <!-- 左侧：游戏网格容器 -->
                <child>
                  <object class="GtkScrolledWindow" id="scrolled_game">
                    <property name="visible">True</property>
                    <property name="can_focus">True</property>
                    <property name="shadow_type">in</property>
                    <property name="hscrollbar_policy">automatic</property>
                    <property name="vscrollbar_policy">automatic</property>
                    <child>
                      <!-- 
                         注意：这里放置一个空的 Grid。
                         100x100 = 10000 个控件太多，不建议直接在 XML 中写死。
                         请在代码中通过 gtk_grid_attach 动态添加彩色按钮/事件框。
                      -->
                      <object class="GtkGrid" id="game_grid_container">
                        <property name="visible">True</property>
                        <property name="can_focus">False</property>
                        <property name="halign">start</property>
                        <property name="valign">start</property>
                      </object>
                    </child>
                  </object>
                  <packing>
                    <property name="resize">True</property>
                    <property name="shrink">True</property>
                  </packing>
                </child>
                
                <!-- 右侧：方向控制按钮 -->
                <child>
                  <object class="GtkBox" id="control_box">
                    <property name="visible">True</property>
                    <property name="can_focus">False</property>
                    <property name="orientation">vertical</property>
                    <property name="halign">center</property>
                    <property name="valign">center</property>
                    <property name="spacing">10</property>
                    <property name="margin_end">20</property>
                    
                    <!-- 上 -->
                    <child>
                      <object class="GtkButton" id="btn_up">
                        <property name="label" translatable="yes">↑ 上</property>
                        <property name="visible">True</property>
                        <property name="can_focus">True</property>
                        <property name="receives_default">True</property>
                        <property name="halign">center</property>
                        <signal name="clicked" handler="on_move_up_clicked" swapped="no"/>
                      </object>
                    </child>
                    
                    <!-- 左 右 并排 -->
                    <child>
                      <object class="GtkBox" id="lr_box">
                        <property name="visible">True</property>
                        <property name="can_focus">False</property>
                        <property name="spacing">10</property>
                        <child>
                          <object class="GtkButton" id="btn_left">
                            <property name="label" translatable="yes">← 左</property>
                            <property name="visible">True</property>
                            <property name="can_focus">True</property>
                            <property name="receives_default">True</property>
                            <signal name="clicked" handler="on_move_left_clicked" swapped="no"/>
                          </object>
                        </child>
                        <child>
                          <object class="GtkButton" id="btn_right">
                            <property name="label" translatable="yes">→ 右</property>
                            <property name="visible">True</property>
                            <property name="can_focus">True</property>
                            <property name="receives_default">True</property>
                            <signal name="clicked" handler="on_move_right_clicked" swapped="no"/>
                          </object>
                        </child>
                      </object>
                    </child>
                    
                    <!-- 下 -->
                    <child>
                      <object class="GtkButton" id="btn_down">
                        <property name="label" translatable="yes">↓ 下</property>
                        <property name="visible">True</property>
                        <property name="can_focus">True</property>
                        <property name="receives_default">True</property>
                        <property name="halign">center</property>
                        <signal name="clicked" handler="on_move_down_clicked" swapped="no"/>
                      </object>
                    </child>
                    
                  </object>
                  <packing>
                    <property name="resize">False</property>
                    <property name="shrink">True</property>
                  </packing>
                </child>
                
              </object>
              <packing>
                <property name="expand">True</property>
                <property name="fill">True</property>
                <property name="position">1</property>
              </packing>
            </child>
            
          </object>
          <packing>
            <property name="name">page_game</property>
            <property name="position">1</property>
          </packing>
        </child>
        <!-- 结算界面 -->
        <child>
         
          <object class="GtkBox" id="checkout_bok">
            <property name="visible">True</property>
            <property name="can_focus">False</property>
            <property name="orientation">vertical</property>
            <property name="halign">center</property>
            <property name="valign">center</property>
            <property name="spacing">10</property>
            <!-- 结算 -->
            <child>
              <object class="GtkLabel" id="label_checkout">
                <property name="visible">True</property>
                <property name="label" translatable="yes">你的分数...</property>
                <property name="xalign">0</property>
                <attributes>
                  <attribute name="weight" value="bold"/>
                  <attribute name="scale" value="1.2"/>
                </attributes>
              </object>
            </child>
            <child>
              <object class="GtkLabel" id="label_checkout_info">
                <property name="visible">True</property>
                <property name="label" translatable="yes">你赢了...</property>
                <property name="xalign">0</property>
                <attributes>
                  <attribute name="weight" value="bold"/>
                  <attribute name="scale" value="1.2"/>
                </attributes>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="btn_back">
                <property name="label" translatable="yes">返回主页</property>
                <property name="visible">True</property>
                <property name="can_focus">True</property>
                <property name="receives_default">True</property>
                <signal name="clicked" handler="on_move_right_clicked" swapped="no"/>
              </object>
            </child>
          </object>
          <packing>
            <property name="name">page_checkout</property>
          </packing>
        </child>
        
      </object>
    </child>
  </object>
  
  <!-- 调整对象：用于端口输入 (0-65535) -->
  <object class="GtkAdjustment" id="adjustment_port">
    <property name="lower">1</property>
    <property name="upper">65535</property>
    <property name="value">25566</property>
    <property name="step_increment">1</property>
    <property name="page_increment">10</property>
  </object>
</interface>